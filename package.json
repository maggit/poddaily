{
  "name": "poddaily",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @poddaily/db generate",
    "db:migrate": "pnpm --filter @poddaily/db migrate",
    "seed": "pnpm --filter @poddaily/db seed",
    "smoke:db": "pnpm --filter @poddaily/db smoke",
    "smoke:auth": "vitest run apps/web/tests/auth-smoke.test.ts tools/slack-stub/src/server.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.16.0"
  }
}

# poddaily self-hosting configuration — copy to .env next to docker-compose.yml.
# Every value here is interpolated into the compose file; nothing else is required.

# ── Image ────────────────────────────────────────────────────────────────────
# Which published image tag to run. `latest` tracks every release; pin a major
# (e.g. `1`) or an exact version (e.g. `1.2.3`) for controlled upgrades.
PODDAILY_TAG=latest

# ── Core ─────────────────────────────────────────────────────────────────────
# Password for the bundled Postgres (also baked into DATABASE_URL by the compose file).
POSTGRES_PASSWORD=change-me

# Session encryption secret for the admin UI (Auth.js). Generate: openssl rand -base64 32
AUTH_SECRET=change-me

# Public URL of the web app (admin UI) — used for auth callbacks and the
# "Connect to post as yourself" links in Slack messages.
NEXTAUTH_URL=https://poddaily.example.com

# Shared secret between the web app and the Slack events receiver.
# Generate: openssl rand -hex 32
INTERNAL_API_SECRET=change-me

# ── Slack app credentials ────────────────────────────────────────────────────
# Create the Slack app from app_manifest.yaml in the repo root (Slack → Create New App →
# From an app manifest), then copy these from the app's Basic Information page.
# The app's event subscriptions + slash command URL must point at the api service:
#   https://<your-api-domain>/slack/events
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# ── Optional ─────────────────────────────────────────────────────────────────
# Display name for your deployment, e.g. your company name. Personalizes the landing
# page's instance banner and sign-in link ("Sign in to Clara" → /team).
# PODDAILY_INSTANCE_NAME=

# How long a standup run stays open before the timeout report posts (milliseconds).
# STANDUP_TIMEOUT_MS=14400000

# Direct (non-pooled) Postgres connection for migrations. Only needed when DATABASE_URL
# points at a transaction-mode pooler (e.g. an external Supabase on port 6543); the
# bundled Postgres needs nothing here.
# DIRECT_URL=

# Slack endpoint overrides — used by the test stub only; never set in production.
# SLACK_API_BASE_URL=
# SLACK_OIDC_BASE=
# SLACK_OAUTH_BASE=
